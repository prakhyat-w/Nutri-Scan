# Copy this file to .env and fill in your values.
# Never commit .env to version control.

SECRET_KEY=change-me-generate-a-long-random-string
DEBUG=True

# Neon free PostgreSQL — connection string from Neon dashboard
# Leave blank to fall back to SQLite for local dev
DATABASE_URL=postgres://user:password@your-neon-host.neon.tech/neondb

# Supabase Storage (for meal photo uploads)
# Settings → API in your Supabase project dashboard
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_ANON_KEY=your-anon-public-key-here
SUPABASE_BUCKET=meal-photos

# USDA FoodData Central — free key from https://api.data.gov/signup
# DEMO_KEY works for light testing (30 req/hr) but register for 1,000/hr
FDC_API_KEY=your-usda-api-key-here

# HuggingFace Spaces sets this automatically.
# For local dev the default "*" is fine.
ALLOWED_HOSTS=*
